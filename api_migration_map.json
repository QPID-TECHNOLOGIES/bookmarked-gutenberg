    },
    {
      "name": "Languages Lookups List",
      "description": "List all language codes present in the database to populate search filters dynamically in the mobile app.",
      "http_method": "GET",
      "path": "/api/v1/languages/",
      "legacy_paths": ["/languages/"],
      "requires_auth": true,
      "query_parameters": {},
