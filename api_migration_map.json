  "endpoints": [
    {
      "name": "API Documentation Portal",
      "description": "Developer landing page, interactive dashboard, and live API request playground.",
      "http_method": "GET",
      "path": "/",
      "requires_auth": false,
      "query_parameters": {},
      "response_content_type": "text/html; charset=utf-8",
      "notes": "Public-facing single page application."
    },
    {
      "name": "System Diagnostics Health Check",
      "description": "Performs diagnostics verifying live PostgreSQL database and S3 Bucketeer storage connectivity.",
      "http_method": "GET",
      "path": "/health/",
      "requires_auth": false,
      "query_parameters": {},
      "response_content_type": "application/json",
      "success_response_sample": {
        "status": "healthy",
        "checks": {
          "database": "healthy",
          "storage": "healthy"
        }
      },
      "failure_response_sample": {
        "status": "unhealthy",
        "checks": {
          "database": "failed",
          "storage": "healthy"
        }
      },
      "notes": "Uptime monitors should query this endpoint (exempted from API Key validation)."
    },
    {
      "name": "Search Autocomplete Suggestions",
      "description": "Exposes lightweight search recommendations suitable for instant search-as-you-type inputs in the app.",
      "http_method": "GET",
      "path": "/api/v1/search/suggest/",
      "legacy_paths": ["/search/suggest/"],
      "requires_auth": true,
      "query_parameters": {
        "q": {
          "type": "string",
          "required": true,
          "description": "Min 2 characters search term to match against book titles, author names, summary text, subjects, and bookshelves."
        }
      },
      "response_content_type": "application/json",
      "success_response_sample": [
        {
          "gutenberg_id": 1513,
          "title": "Romeo and Juliet",
          "author": "William Shakespeare",
          "match_field": "title",
          "book": {
            "id": 1513,
            "title": "Romeo and Juliet",
            "authors": [
              {
                "name": "William Shakespeare",
                "birth_year": 1564,
                "death_year": 1616
              }
            ],
            "summaries": ["A tragic love story..."],
            "translators": [],
            "editors": [],
            "subjects": ["Tragedy"],
            "bookshelves": ["Classic Drama"],
            "languages": ["English"],
            "copyright": false,
            "media_type": "Text",
            "formats": {
              "application/epub+zip": "https://www.gutenberg.org/ebooks/1513.epub3.images",
              "text/html": "https://www.gutenberg.org/ebooks/1513.html.images"
            },
            "download_count": 12034
          }
        }
      ],
      "notes": "Highly optimized query fetching top 10 matching books across titles, authors, summaries, subjects, and bookshelves. Prefetches related elements to ensure response latency < 25ms."
    },
    {
      "name": "Books Metadata Catalog List",
      "description": "Retrieve catalog book details. Supports pagination, sorting, search, and criteria filtering.",
      "http_method": "GET",
      "path": "/api/v1/books/",
      "legacy_paths": ["/books/"],
      "requires_auth": true,
      "query_parameters": {
        "page": {
          "type": "integer",
          "required": false,
          "description": "Page number to view (defaults to page 1)."
        },
        "search": {
          "type": "string",
          "required": false,
          "description": "Case-insensitive terms matching author names and book titles."
        },
        "languages": {
          "type": "string",
          "required": false,
          "description": "Comma-separated two-character language codes (e.g. 'en,fr')."
        },
        "copyright": {
          "type": "string",
          "required": false,
          "description": "Filter by copyright status: 'true' (copyrighted), 'false' (public domain), or 'null'."
        },
        "author_year_start": {
          "type": "integer",
          "required": false,
          "description": "Filters books with authors alive after this year."
        },
        "author_year_end": {
          "type": "integer",
          "required": false,
          "description": "Filters books with authors alive before this year."
        },
        "ids": {
          "type": "string",
          "required": false,
          "description": "Comma-separated list of positive Gutenberg IDs (e.g. '11,12,13')."
        },
        "mime_type": {
          "type": "string",
          "required": false,
          "description": "Filters by format MIME types starting with value (e.g. 'text/html')."
        },
        "topic": {
          "type": "string",
          "required": false,
          "description": "Matches keyword inside bookshelves or subjects."
        },
        "sort": {
          "type": "string",
          "required": false,
          "description": "Ordering types: 'popular' (default, download count), 'ascending' (ID order), 'descending'."
        }
      },
      "response_content_type": "application/json",
      "success_response_sample": {
        "count": 72480,
        "next": "https://gutenberg-bookmarked-737fe6b6f1ee.herokuapp.com/api/v1/books/?page=2",
        "previous": null,
        "results": [
          {
            "id": 84,
            "title": "Frankenstein; or, the modern prometheus",
            "authors": [
              {
                "name": "Mary Wollstonecraft Shelley",
                "birth_year": 1797,
                "death_year": 1851
              }
            ],
            "translators": [],
            "editors": [],
            "subjects": [
              "Frankenstein's monster (Fictitious character)",
              "Horror tales",
              "Monster fiction",
              "Science fiction",
              "Scientists"
            ],
            "bookshelves": [
              "Precursors of Science Fiction",
              "Science Fiction by Women"
            ],
            "languages": ["English"],
            "copyright": false,
            "media_type": "Text",
            "formats": {
              "application/epub+zip": "https://www.gutenberg.org/ebooks/84.epub3.images",
              "text/html": "https://www.gutenberg.org/ebooks/84.html.images"
            },
            "download_count": 92345
          }
        ]
      },
      "notes": "Optimized using prefetch_related for relationship joins, dropping server response times to ~90ms. Title, authors, languages, and subjects are auto-cleaned for direct user presentation."
    },
    {
      "name": "Individual Book Details",
      "description": "Fetch catalog metadata for a single specific book.",
