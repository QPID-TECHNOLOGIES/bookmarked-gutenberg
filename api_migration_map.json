      }
    },
    {
      "name": "Request Ebook Cache Job",
      "description": "Trigger dynamic S3 caching check and Gutenberg mirror fetch. Used to download books without triggering 30s router timeouts.",
      "http_method": "GET",
      "path": "/api/v1/content/{gutenberg_id}/",
      "legacy_paths": ["/content/{gutenberg_id}/"],
      "requires_auth": true,
      "query_parameters": {
        "format": {
          "type": "string",
          "required": false,
          "description": "Target format (defaults to 'epub'). Supported: 'epub', 'txt', 'plain', 'html', 'kindle'."
        }
      },
      "response_content_type": "application/json",
      "response_codes": {
        "302": {
          "description": "Cache Hit. Automatically redirects to the secure S3 Presigned download URL."
        },
        "202": {
          "description": "Cache Miss. Job enqueued for background worker.",
          "sample_payload": {
            "status": "pending",
            "gutenberg_id": "84",
            "format": "application/epub+zip",
            "message": "Content is being prepared. Poll /status/ for updates.",
            "status_url": "/content/84/status/?format=epub"
          }
        }
      }
    },
    {
      "name": "Ebook Cache Job Status / Download Url",
      "description": "Poll the caching status. Returns status checks and the final S3 download URL.",
      "http_method": "GET",
      "path": "/api/v1/content/{gutenberg_id}/status/",
      "legacy_paths": ["/content/{gutenberg_id}/status/"],
      "requires_auth": true,
      "query_parameters": {
        "format": {
          "type": "string",
          "required": false,
          "description": "Target format (defaults to 'epub')."
        }
      },
      "response_content_type": "application/json",
      "states": {
        "pending": {
          "status": "pending",
          "gutenberg_id": "84",
          "format": "application/epub+zip"
        },
        "fetching": {
          "status": "fetching",
          "gutenberg_id": "84",
          "format": "application/epub+zip"
        },
        "failed": {
          "status": "failed",
          "gutenberg_id": "84",
          "format": "application/epub+zip",
          "error": "Error details, retry enqueued automatically."
        },
        "ready": {
          "status": "ready",
          "gutenberg_id": "84",
          "format": "application/epub+zip",
          "url": "https://bucketeer-a40dd3d4-d3bf-41be-bf7d-fa03be6746d7.s3.amazonaws.com/books/84/pg84.epub?X-Amz-Algorithm=AWS4-HMAC-SHA256&X-Amz-Credential=...",
          "file_size_bytes": 356363,
          "completed_at": "2026-07-13T15:49:51.591845"
        }
      },
      "notes": "When state is 'ready', the 'url' field contains a secure temporary S3 Presigned URL (valid for 1 hour). Use 'file_size_bytes' to drive the mobile app's download progress percentage tracker."
    }
  ]
